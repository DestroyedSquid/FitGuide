<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="650.0" prefWidth="1050.0"
      style="-fx-background-color: linear-gradient(to bottom, #E8F5E9, #B2DFDB);"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="omr.uacm.sistemafitguide.controlador.PantallaListaEjerciciosController">

    <HBox alignment="CENTER_LEFT" prefHeight="64.0" minHeight="64.0" maxHeight="64.0"
          style="-fx-background-color: #2E7D32; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 8, 0, 0, 4);">
        <padding><Insets left="20.0" right="20.0" /></padding>

        <!-- Botón Menú -->
        <Button onAction="#regresarMenu" prefHeight="36.0" prefWidth="90.0"
                style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 18; -fx-cursor: hand;"
                text="← Menú" />

        <Region HBox.hgrow="ALWAYS" />

        <!-- Tabs de músculo -->
        <HBox alignment="CENTER" spacing="6.0">
            <Button fx:id="btnTabBrazo" onAction="#seleccionarBrazo"
                    prefHeight="40.0" prefWidth="140.0"
                    style="-fx-background-color: white; -fx-text-fill: #2E7D32; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 20; -fx-cursor: hand;"
                    text=" Brazo" />
            <Button fx:id="btnTabAbdomen" onAction="#seleccionarAbdomen"
                    prefHeight="40.0" prefWidth="140.0"
                    style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 20; -fx-cursor: hand;"
                    text=" Abdomen" />
            <Button fx:id="btnTabPierna" onAction="#seleccionarPierna"
                    prefHeight="40.0" prefWidth="140.0"
                    style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 20; -fx-cursor: hand;"
                    text=" Pierna" />
        </HBox>

        <Region HBox.hgrow="ALWAYS" />

        <Label fx:id="lblMusculoActivo"
               style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.8); -fx-font-style: italic;"
               text="Brazo" />
        <Region prefWidth="10.0" />
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;"
                VBox.vgrow="ALWAYS">

        <VBox fx:id="contenedorRutinas" spacing="0.0"
              style="-fx-background-color: transparent;">
            <padding><Insets bottom="30.0" left="30.0" right="30.0" top="20.0" /></padding>

            <!-- ── Sección PESO PROPIO ── -->
            <VBox fx:id="seccionPesoPropio" spacing="12.0">

                <!-- Separador / título sección -->
                <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-padding: 8 0 4 0;">
                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;
                                  -fx-background-color: #388E3C; -fx-background-radius: 20;
                                  -fx-padding: 4 16;"
                           text="PESO PROPIO" />
                    <Region HBox.hgrow="ALWAYS"
                            style="-fx-background-color: #A5D6A7; -fx-pref-height: 2; -fx-max-height: 2;" />
                </HBox>

                <!-- Fila de tarjetas peso propio -->
                <HBox fx:id="filaCardsPropio" alignment="TOP_LEFT" spacing="16.0" />

            </VBox>

            <Region prefHeight="20.0" />

            <!-- ── Sección PESO EXTRA ── -->
            <VBox fx:id="seccionPesoExtra" spacing="12.0">

                <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-padding: 8 0 4 0;">
                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;
                                  -fx-background-color: #C62828; -fx-background-radius: 20;
                                  -fx-padding: 4 16;"
                           text="PESO EXTRA" />
                    <Region HBox.hgrow="ALWAYS"
                            style="-fx-background-color: #EF9A9A; -fx-pref-height: 2; -fx-max-height: 2;" />
                </HBox>

                <!-- Fila de tarjetas peso extra -->
                <HBox fx:id="filaCardsExtra"  alignment="TOP_LEFT" spacing="16.0" />

            </VBox>

            <!-- Mensaje cuando no hay rutinas -->
            <VBox fx:id="panelSinRutinas" visible="false" managed="false"
                  alignment="CENTER" spacing="12.0" style="-fx-padding: 60 0;">
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #4A7C59;"
                       text="Sin rutinas configuradas" />
                <Label style="-fx-font-size: 14px; -fx-text-fill: #6A9E77; -fx-text-alignment: center;"
                       text="Ve al menú principal → Personalizar Rutina para crear tus rutinas." wrapText="true" maxWidth="500.0" />
            </VBox>

        </VBox>
    </ScrollPane>

</VBox>
