<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="900.0" spacing="20.0" style="-fx-background-color: #F4F4F4;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="omr.uacm.sistemafitguide.controlador.PantallaPerfilController">
    <children>
        <Label text="MI PERFIL BIOMÉTRICO" textFill="#2d3e40">
            <font> <Font name="System Bold" size="28.0" /> </font>
        </Label>

        <VBox alignment="CENTER" maxWidth="500.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" padding="30.0">
            <children>
                <Label fx:id="lblNombre" text="NOMBRE USUARIO" textFill="#387373">
                    <font> <Font name="System Bold" size="22.0" /> </font>
                </Label>

                <HBox alignment="CENTER" spacing="50.0">
                    <children>
                        <VBox alignment="CENTER">
                            <Label text="Edad:" textFill="GREY" />
                            <Label fx:id="lblEdad" text="-- años">
                                <font> <Font name="System Bold" size="16.0" /> </font>
                            </Label>
                        </VBox>
                        <VBox alignment="CENTER">
                            <Label text="Estatura:" textFill="GREY" />
                            <Label fx:id="lblEstatura" text="-- m">
                                <font> <Font name="System Bold" size="16.0" /> </font>
                            </Label>
                        </VBox>
                    </children>
                </HBox>

                <HBox alignment="CENTER" spacing="10.0" style="-fx-background-color: #E8F0F0; -fx-background-radius: 10;" padding="10.0">
                    <Label text="Peso Actual (kg):">
                        <font> <Font name="System Bold" size="14.0" /> </font>
                    </Label>
                    <TextField fx:id="txtNuevoPeso" prefWidth="80.0" />
                    <Button mnemonicParsing="false" onAction="#accionActualizarPeso" style="-fx-background-color: #387373; -fx-text-fill: white; -fx-font-weight: bold;" text="Actualizar" />
                </HBox>

                <VBox alignment="CENTER" spacing="5.0">
                    <Label text="Índice de Masa Corporal (IMC):" textFill="GREY" />
                    <Label fx:id="lblIMC" text="--">
                        <font> <Font name="System Bold" size="36.0" /> </font>
                    </Label>
                    <Label fx:id="lblCategoriaIMC" text="--" textFill="#387373">
                        <font> <Font name="System Bold Italic" size="18.0" /> </font>
                    </Label>
                </VBox>

                <VBox alignment="CENTER" spacing="5.0">
                    <Label text="Porcentaje de Grasa Corporal:" textFill="GREY" />
                    <Label fx:id="lblGrasa" text="-- %">
                        <font> <Font name="System Bold" size="20.0" /> </font>
                    </Label>
                </VBox>
            </children>
        </VBox>

        <Button mnemonicParsing="false" onAction="#accionVolverMenu" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #2D3E40; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20;" text="Volver al Inicio" />
    </children>
</VBox>